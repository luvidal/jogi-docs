{
  "name": "@jogi/docs",
  "version": "0.1.1",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./doctypes": {
      "types": "./dist/doctypes/index.d.ts",
      "import": "./dist/doctypes/index.mjs",
      "require": "./dist/doctypes/index.js"
    },
    "./multipart": {
      "types": "./dist/multipart/index.d.ts",
      "import": "./dist/multipart/index.mjs",
      "require": "./dist/multipart/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "cli": "tsx dev/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-rekognition": "^3.1007.0",
    "@google/genai": "^0.9.0",
    "openai": "^4.82.0",
    "pdf-lib": "^1.17.1",
    "pdf-to-png-converter": "^3.5.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
